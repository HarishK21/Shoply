# Required
MONGODB_URI=mongodb://127.0.0.1:27017/Shoply
PORT=8080

# Optional security controls
SESSION_TTL_MS=604800000
REQUEST_BODY_LIMIT=32kb
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX=5

# Optional seed users (JSON array)
# Example:
# SEED_USERS_JSON=[{"name":"Admin","email":"admin@example.com","password":"change-me-now","role":"admin"}]
SEED_USERS_JSON=

